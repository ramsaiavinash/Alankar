{
  "name": "alankar-pooja-stores",
  "version": "1.0.0",
  "description": "Alankar Pooja Stores — Sales Management Desktop App",
  "main": "main.js",
  "author": "Alankar Pooja Stores",
  "license": "Proprietary",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build-win": "electron-builder --win nsis",
    "build-portable": "electron-builder --win portable",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.alankar.poojastore",
    "productName": "Alankar Pooja Stores",
    "files": ["**/*", "!node_modules/.cache", "!dist", "!.git"],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "AlankarPoojaStores-Portable-${version}.exe"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Alankar Pooja Stores"
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "@electron/rebuild": "^3.6.0"
  }
}
